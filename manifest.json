{
  "manifest_version": 3,
  "name": "Google Calendar URL Retriever",
  "version": "1.0.0",
  "description": "Google Calendar の予定からミーティングURLと日付をワンクリックでコピー",
  "permissions": ["clipboardWrite"],
  "content_scripts": [
    {
      "matches": ["https://calendar.google.com/*"],
      "js": ["src/selectors.js", "src/content.js"],
      "css": ["src/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
